  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  preguntas:
  - categoria: Reading
    enunciado: "What does 'deforestation' mean?\n(\xBFQu\xE9 significa 'deforestaci\xF3n'?)"
    opciones:
    - Planting more trees
    - Removing trees from forests
    - Protecting forests
    - Growing city gardens
    indiceCorrecto: 1
  - categoria: Listening
    enunciado: "Which action helps REDUCE pollution?\n(\xBFQu\xE9 acci\xF3n ayuda
      a REDUCIR la contaminaci\xF3n?)"
    opciones:
    - Burning garbage
    - Using plastic bags
    - Riding a bicycle
    - Leaving lights on
    indiceCorrecto: 2
  - categoria: Writing
    enunciado: 'Complete: ''We must _____ water to protect our planet.'''
    opciones:
    - waste
    - pollute
    - ignore
    - save
    indiceCorrecto: 3
  - categoria: Reading
    enunciado: "What is 'climate change'?\n(\xBFQu\xE9 es el 'cambio clim\xE1tico'?)"
    opciones:
    - Changes in weather over long periods
    - Daily temperature shifts
    - The four seasons
    - Rain during summer
    indiceCorrecto: 0
  - categoria: Writing
    enunciado: "Which word means 'to use something again'?\n(\xBFCu\xE1l palabra
      significa 'volver a usar algo'?)"
    opciones:
    - Dispose
    - Purchase
    - Recycle
    - Waste
    indiceCorrecto: 2
