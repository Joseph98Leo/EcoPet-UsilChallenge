  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Hola, soy Nilo. Vivo en las costas rocosas del Per\xFA. El oc\xE9ano que
    era mi hogar est\xE1 lleno de basura y los peces que como est\xE1n desapareciendo.
    El petr\xF3leo derramado manch\xF3 mis plumas y ahora no puedo nadar bien ni
    mantenerme caliente. \xBFMe ayudas a limpiarme y recuperarme?\r\n\r\nHi, I'm
    Nilo. I live on the rocky coasts of Peru. The ocean that was my home is full
    of garbage and the fish I eat are disappearing. Spilled oil stained my feathers
    and now I can't swim well or stay warm. Will you help me clean up and recover?"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: a1f6ec866d5af1543bc003a12a392b18, type: 2}
  m_sharedMaterial: {fileID: -6518909469830510645, guid: a1f6ec866d5af1543bc003a12a392b18, type: 2}
